# /etc/containers/systemd/qwen3-asr.container

[Unit]
Description=Qwen3-ASR
After=network-online.target
Wants=network-online.target

[Container]
ContainerName=qwen3-asr
Pod=smarthome.pod
Image=ghcr.io/malaiwah/qwen3-asr-server:latest
AutoUpdate=registry
Pull=newer

AddDevice=nvidia.com/gpu=all
SecurityLabelDisable=true
PodmanArgs=--ipc=host


Volume=qwen3asr.volume:/root/.cache/huggingface:z

[Service]
Restart=always
RestartSec=15
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target