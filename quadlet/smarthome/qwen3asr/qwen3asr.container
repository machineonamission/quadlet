# /etc/containers/systemd/qwen3-asr.container

[Unit]
Description=Qwen3-ASR
After=network-online.target
Wants=network-online.target

[Container]
ContainerName=qwen3-asr
Pod=smarthome.pod
Image=ghcr.io/malaiwah/qwen3-asr-server:latest
AutoUpdate=registry
Pull=newer

AddDevice=nvidia.com/gpu=all
SecurityLabelDisable=true
PodmanArgs=--ipc=host


Volume=qwen3asr.volume:/root/.cache/huggingface:z

Environment=QWEN3_ASR_MODEL_ID=Qwen/Qwen3-ASR-0.6B
Environment=GPU_MEMORY_UTILIZATION=0.65
Environment=VLLM_EXTRA_ARGS=--enforce-eager
Exec=--gpu-memory-utilization 0.65

[Service]
Restart=always

[Install]
WantedBy=multi-user.target