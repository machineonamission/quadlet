[Unit]
Description=vLLM Qwen3-ASR
After=network-online.target

[Container]
Pod=smarthome.pod
ContainerName=vllm
AutoUpdate=registry
Pull=newer
Image=docker.io/vllm/vllm-openai:latest

# Model
#Environment=HUGGING_FACE_HUB_TOKEN=your_token_here
Environment=HF_HOME=/root/.cache/huggingface

Volume=vllm.volume:/root/.cache/huggingface:z

Exec=--max-model-len 896 \
     --dtype auto \
     --host 0.0.0.0 \
     --port 8085 \
     --load-in-8bit \
     Qwen/Qwen3-ASR-1.7B

AddDevice=nvidia.com/gpu=all

[Service]
Restart=always
TimeoutStartSec=600

[Install]
WantedBy=default.target